{
  "name": "agent-harness-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A minimal TypeScript Node agent harness for experimenting with Recursive Language Model ideas.",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude tests/pty/**",
    "test:pty": "npm run build && vitest run --passWithNoTests tests/pty/*.test.ts",
    "dev": "npm run build && node dist/main.js",
    "start": "node dist/main.js"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@earendil-works/pi-tui": "^0.79.3",
    "ai": "latest",
    "cli-highlight": "^2.1.11",
    "pyodide": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "node-pty": "^1.1.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
